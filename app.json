{
  "expo": {
    "name": "Grimoire Words",
    "slug": "grimoire-words",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "grimoire",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A0A00"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.asakov.grimoire"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A0A00"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.asakov.grimoire"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-1326375857154070~5173339856",
          "iosAppId": "ca-app-pub-1326375857154070~8015464924"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fe9cd172-87f8-4797-a361-3e19253761e5"
      }
    },
    "owner": "sundrs-organization"
  }
}
